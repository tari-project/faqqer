# .env.example — copy to .env and fill in real values before running
# docker compose up -d
#
# Lines beginning with # are comments.  Every variable used by the bridge
# or the compose file is documented here.

# ---------------------------------------------------------------------------
# LLM provider (used by AnythingLLM, not the bridge directly)
# ---------------------------------------------------------------------------

# Your OpenAI API key.  Required when LLM_PROVIDER=openai (the default).
OPENAI_API_KEY=your-openai-key-here

# Which OpenAI model AnythingLLM should use for answering questions.
# gpt-4o-mini is cheap and fast; upgrade to gpt-4o for better accuracy.
OPENAI_MODEL=gpt-4o-mini

# AnythingLLM supports many providers; change this and remove OPENAI_API_KEY
# if you want to use Anthropic, Azure, Ollama, LocalAI, etc.
LLM_PROVIDER=openai

# Vector store backend.  lancedb is built-in and requires no extra service.
VECTOR_DB=lancedb

# ---------------------------------------------------------------------------
# AnythingLLM connection (bridge → AnythingLLM)
# ---------------------------------------------------------------------------

# Internal URL used by the bridge container to reach AnythingLLM.
# When running via docker compose this must stay as-is (service name = hostname).
ANYTHINGLLM_BASE_URL=http://anythingllm:3001

# API key for the bridge to authenticate with AnythingLLM.
# Generate one in the admin UI: Settings → API Keys → Create new key.
# REQUIRED — the bridge will refuse to start without this.
ANYTHINGLLM_API_KEY=

# Slug of the AnythingLLM workspace that holds the Tari knowledge base.
# The bridge will create the workspace automatically on first start if it
# does not exist, using this slug.
ANYTHINGLLM_WORKSPACE=tari

# ---------------------------------------------------------------------------
# Telegram — Q&A bot (python-telegram-bot)
# ---------------------------------------------------------------------------

# BotFather token for the Q&A bot (@mention / /ask command responder).
# Leave blank to disable Telegram Q&A.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs that are allowed to /approve
# answers so they get written back into the knowledge base.
TELEGRAM_ADMIN_USER_IDS=

# Comma-separated list of group IDs the bridge should announce into
# (used by the legacy blockchain stats job).
TELEGRAM_ANNOUNCE_GROUP_IDS=

# Comma-separated list of public channel usernames (without @) that the
# customer-analysis job reads messages from.
TELEGRAM_ANALYSIS_CHANNELS=tariproject

# Group / supergroup ID where customer-analysis results are posted.
TELEGRAM_CUSTOMER_SERVICE_GROUP_ID=

# ---------------------------------------------------------------------------
# Telegram — legacy Telethon credentials (required for blockchain & analysis jobs)
# ---------------------------------------------------------------------------
# These are user-account credentials, not bot credentials.
# Obtain them from https://my.telegram.org/apps.
# Leave blank to disable the blockchain stats and customer analysis jobs.

TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Name used for the local Telethon session file (stored in BRIDGE_DATA_DIR).
TELEGRAM_SESSION_NAME=tari_bridge

# ---------------------------------------------------------------------------
# Discord — Q&A bot (discord.py)
# ---------------------------------------------------------------------------

# Discord bot token from https://discord.com/developers/applications.
# Leave blank to disable Discord Q&A.
DISCORD_BOT_TOKEN=

# Numeric ID of your Discord server (guild).  Used to register slash commands
# instantly (guild-scoped) rather than waiting up to an hour for global sync.
DISCORD_GUILD_ID=

# Comma-separated numeric role IDs whose members can run !approve.
DISCORD_ADMIN_ROLE_IDS=

# ---------------------------------------------------------------------------
# Feature flags — set to "false" to disable individual subsystems
# ---------------------------------------------------------------------------

ENABLE_TELEGRAM_QA=true
ENABLE_DISCORD_QA=true
ENABLE_BLOCKCHAIN_JOBS=true
ENABLE_CUSTOMER_ANALYSIS_JOB=true

# ---------------------------------------------------------------------------
# Bridge runtime paths (these are set automatically in docker-compose.yml;
# only override them when running the bridge outside of Docker)
# ---------------------------------------------------------------------------

# Directory where the bridge stores its SQLite jobstore and feedback cache.
BRIDGE_DATA_DIR=./data

# Directory containing FAQ text/markdown files to seed the knowledge base.
BRIDGE_FAQ_DIR=./faqs
